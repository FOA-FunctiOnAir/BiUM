{
  "BiAppOptions": {
    "Environment": "Development",
    "Domain": "Test2",
    "DomainVersion": "v1",
    "Port": 5001
  },
  "BoltOptions": {
    "Enable": true,
    "Branch": "Local",
    "Server": "/api/bolt/BoltEntity/SaveFwBoltEntity",
    "ConnectionString": "Host=<your-bolt-postgres-host>; Port=<port>; Database={0}; Username=<user>; Password=<password>;"
  },
  "DatabaseType": "PostgreSQL",
  "ConnectionStrings": {
    "MSSQL": "Server=(localdb)\\mssqllocaldb;Database=BiAppAuthDb;Trusted_Connection=True;MultipleActiveResultSets=true",
    "PostgreSQL": "Host=<your-postgres-host>; Port=<port>; Database=<your-database>; Username=<user>; Password=<password>;"
  },
  "RedisClientOptions": {
    "Enable": true,
    "DefaultCacheTimeout": "3000",
    "ConnectionString": "<redis-host>:<port>, password=<password>, abortConnect=false"
  },
  "RabbitMQOptions": {
    "Enable": true,
    "Hostname": "<your-rabbitmq-host>",
    "Port": 5672,
    "VirtualHost": "",
    "Username": "<user>",
    "Password": "<password>"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
